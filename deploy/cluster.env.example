# Reverse Rusty production cluster — environment for deploy/compose.cluster.yml.
# Copy to deploy/cluster.env (git-ignored) and fill in the REQUIRED values, then run
# from the repo root:
#   docker compose --project-directory . -f deploy/compose.cluster.yml \
#     --env-file deploy/cluster.env up -d --wait
# Full procedure + the trust model: docs/operations/cluster-deployment.md.

# The node image. Build once from the repo root:
#   docker build -f deploy/Dockerfile -t reverse-rusty:latest .
RR_IMAGE=reverse-rusty:latest

# REQUIRED — the shared mesh secret attached to every gRPC RPC between coordinator,
# shards, and control plane (ADR-071). Generate a strong value and keep it secret:
#   openssl rand -hex 32
# Read from the environment by every bin (resolve_mesh_token / RR_CLUSTER_TOKEN), so
# it never appears in a process listing the way a --cluster-token flag would.
RR_CLUSTER_TOKEN=

# REQUIRED once the coordinator is reachable beyond loopback — the HTTP bearer token
# that gates mutating/admin REST endpoints (_doc, _bulk, _flush, _compact, _vocab,
# _settings, _backup; ADR-062). Distinct audience from RR_CLUSTER_TOKEN. Generate:
#   openssl rand -hex 32
# Leave empty ONLY if RR_PORT stays loopback-bound on a trusted host.
RR_AUTH_TOKEN=

# Host directory holding the mesh identity (ca.crt + node.crt + node.key), produced
# by deploy/gen-mesh-certs.sh. Mounted read-only at /certs in every container. A
# relative path resolves from the repo root ONLY when you pass `--project-directory .`
# (see above); otherwise use an absolute path.
RR_CERT_DIR=./deploy/certs

# Where the coordinator's REST API (port 9200) is published on the host. The default
# binds LOOPBACK ONLY — the API is not reachable off-box. Widen to 0.0.0.0:9200 only
# behind a firewall/reverse proxy AND with RR_AUTH_TOKEN set.
RR_PORT=127.0.0.1:9200
